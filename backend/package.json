{
  "name": "uespay",
  "version": "1.0.0",
  "description": "Sistema de carteira digital universitária para modernização do acesso e pagamento de serviços dentro da universidade, com foco inicial no Restaurante Universitário (RU) da UESPI.",
  "main": "src/server.ts",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "seed": "ts-node src/utils/seed.ts",
    "test:unitario": "vitest run",
    "test:cobertura": "vitest run --coverage"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/les-prp-uespi/uespay.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/les-prp-uespi/uespay/issues"
  },
  "homepage": "https://github.com/les-prp-uespi/uespay#readme",
  "dependencies": {
    "@hyperledger/firefly-sdk": "^1.3.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^4.1.7",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
