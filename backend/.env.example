# UesPay - Variáveis de Ambiente

# Copie este arquivo para .env e preencha os valores:
#   cp .env.example .env

# Porta do servidor Express
PORT=3000

# Hyperledger FireFly
# URL do sandbox local do FireFly (padrão: http://localhost:5000)
FIREFLY_URL=http://localhost:5000
# Namespace do FireFly (padrão: "default")
FIREFLY_NAMESPACE=default
